{
  "name": "handsplus-website",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "scripts": {
    "predev": "node scripts/ensure-next-dev-cache.js",
    "dev": "node scripts/run-next.js dev -p 3002",
    "dev:turbo": "node scripts/run-next.js dev --turbo",
    "clean": "node scripts/rm-next-cache.js",
    "dev:clean": "npm run clean && npm run dev",
    "prebuild": "node scripts/prebuild-clean-win.js",
    "postbuild": "node scripts/mark-next-production.js",
    "build": "node scripts/run-next.js build",
    "start": "node scripts/run-next.js start",
    "lint": "node scripts/run-next.js lint",
    "lighthouse": "npx --yes lighthouse http://localhost:3001 --output=json --output=html --output-path=./lighthouse-report --only-categories=performance,accessibility,best-practices,seo --chrome-flags=\"--headless --no-sandbox\"",
    "lighthouse:prod": "npx --yes lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.report.json --only-categories=performance,accessibility,best-practices,seo --chrome-flags=\"--headless --no-sandbox --disable-gpu\"",
    "lighthouse:report": "node scripts/lighthouse-report-to-pdf.js",
    "lighthouse:desktop": "node scripts/lighthouse-report-desktop.js"
  },
  "dependencies": {
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
